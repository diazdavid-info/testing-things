---
import Layout from "../layouts/Layout.astro";
import CreateGameButton from "../components/CreateGameButton.astro";
import JoinGameForm from "../components/JoinGameForm.astro";
import BoardDecoration from "../components/BoardDecoration.astro";
---

<Layout>
  <div class="relative w-full max-w-lg mx-auto px-6">
    <BoardDecoration
      size={280}
      class="absolute -right-32 top-20 text-text-primary opacity-5 hidden lg:block"
    />
    <BoardDecoration
      size={200}
      class="absolute -left-28 -top-16 text-text-primary opacity-3 hidden lg:block"
    />

    <div class="relative bg-bg-surface border border-border rounded-2xl p-8 sm:p-12 flex flex-col items-center gap-10">
      <div class="flex flex-col items-center gap-3">
        <h1 class="font-heading text-4xl sm:text-5xl font-bold tracking-tight text-text-primary">
          El Molino
        </h1>
        <p class="text-center text-text-secondary text-sm sm:text-base leading-relaxed max-w-xs">
          El clasico juego de estrategia, ahora online
        </p>
      </div>

      <div class="w-full flex flex-col gap-6">
        <CreateGameButton />

        <p
          id="create-error"
          class="hidden text-sm text-error"
          role="alert"
        ></p>

        <div class="flex items-center gap-4 w-full">
          <div class="flex-1 h-px bg-border"></div>
          <span class="text-sm text-text-muted">o</span>
          <div class="flex-1 h-px bg-border"></div>
        </div>

        <JoinGameForm />
      </div>
    </div>
  </div>
</Layout>
