---
import Layout from "../../layouts/Layout.astro";
import WaitingRoom from "../../components/WaitingRoom.astro";
import GameNotFound from "../../components/GameNotFound.astro";
import GameFull from "../../components/GameFull.astro";
import GameFinished from "../../components/GameFinished.astro";
import AutoJoinScreen from "../../components/AutoJoinScreen.astro";
import GamePlayingLayout from "../../components/GamePlayingLayout.astro";
import GameResult from "../../components/GameResult.astro";
import { getGameByCode } from "../../lib/game";
import type { PlayerKey } from "../../lib/game";

const { code } = Astro.params;
const game = code ? getGameByCode(code) : null;

const cookieName = `playerId_${code}`;
const playerId = Astro.cookies.get(cookieName)?.value ?? null;

const isPlayer1 = playerId != null && game?.player1.id === playerId;
const isPlayer2 = playerId != null && game?.player2?.id === playerId;
const isKnownPlayer = isPlayer1 || isPlayer2;
const playerKey: PlayerKey = isPlayer2 ? "player2" : "player1";

const pageTitle = game
  ? `Partida ${code} — El Molino`
  : "Partida no encontrada — El Molino";
const pageDescription = game
  ? game.status === "playing"
    ? "Partida en curso — El Molino"
    : `Unete a la partida ${code} del Molino. Abre este link para jugar.`
  : "La partida que buscas no existe o ha expirado.";

const playerProps = game && game.player2 ? {
  player1: { piecesToPlace: game.player1.piecesToPlace, piecesOnBoard: game.player1.piecesOnBoard },
  player2: { piecesToPlace: game.player2.piecesToPlace, piecesOnBoard: game.player2.piecesOnBoard },
} : null;
---

<Layout title={pageTitle} description={pageDescription}>
  {!game ? (
    <GameNotFound />
  ) : game.status === "waiting" && isPlayer1 ? (
    <WaitingRoom code={code!} playerId={playerId!} />
  ) : game.status === "waiting" && !isKnownPlayer ? (
    <AutoJoinScreen code={code!} />
  ) : game.status === "playing" && isKnownPlayer && playerProps ? (
    <GamePlayingLayout
      board={game.board}
      turn={game.turn}
      phase={game.phase}
      turnState={game.turnState}
      playerKey={playerKey}
      code={code!}
      playerId={playerId!}
      currentPlayer={playerKey === "player1" ? game.player1 : game.player2!}
      player1={playerProps.player1}
      player2={playerProps.player2}
    />
  ) : game.status === "playing" && !isKnownPlayer ? (
    <GameFull />
  ) : game.status === "finished" && isKnownPlayer && playerProps ? (
    <GamePlayingLayout
      board={game.board}
      turn={game.turn}
      phase={game.phase}
      turnState={game.turnState}
      playerKey={playerKey}
      code={code!}
      playerId={playerId!}
      currentPlayer={playerKey === "player1" ? game.player1 : game.player2!}
      player1={playerProps.player1}
      player2={playerProps.player2}
      disabled
    >
      <GameResult winner={game.winner!} playerKey={playerKey} winReason={game.winReason} code={code!} playerId={playerId!} rematchGameCode={game.rematchGameCode} />
    </GamePlayingLayout>
  ) : game.status === "finished" ? (
    <GameFinished />
  ) : null}
</Layout>

{game && game.status === "waiting" && (
  <Fragment>
    <meta slot="head" property="og:title" content="Te han retado a jugar al Molino!" />
    <meta slot="head" property="og:description" content="Abre este link para unirte a la partida y empezar a jugar" />
  </Fragment>
)}
{game && game.status === "playing" && (
  <Fragment>
    <meta slot="head" property="og:title" content="Partida en curso — El Molino" />
    <meta slot="head" property="og:description" content="Esta partida ya esta en curso. Crea tu propia partida para jugar." />
  </Fragment>
)}

<script>
  import { initSSE } from "../../lib/sse-client";

  const boardContainer = document.getElementById("board-container");
  const waitingRoom = document.getElementById("waiting-room");
  const gameCode = boardContainer?.dataset.code || waitingRoom?.dataset.code;
  const ssePlayerId = boardContainer?.dataset.playerId || waitingRoom?.dataset.playerId || "";
  const ssePlayerKey = boardContainer?.dataset.playerKey || "player1";
  const connIndicator = document.getElementById("conn-indicator");
  const disconnBanner = document.getElementById("disconnect-banner");

  if (gameCode && (boardContainer || waitingRoom)) {
    initSSE({
      gameCode,
      playerId: ssePlayerId,
      playerKey: ssePlayerKey,
      onStateChange: () => window.location.reload(),
      onConnectionStatusChange: (status) => {
        if (!connIndicator) return;
        connIndicator.dataset.status = status;
        const txt = connIndicator.querySelector(".conn-text") as HTMLElement;
        if (txt) txt.textContent = status === "disconnected" ? "Reconectando..." : "";
      },
      onDisconnectBannerUpdate: (rivalConnected, elapsed) => {
        if (!disconnBanner) return;
        if (!rivalConnected) {
          disconnBanner.style.display = "flex";
          const claimBtn = document.getElementById("claim-victory-btn");
          if (claimBtn && elapsed >= 5 * 60 * 1000) {
            claimBtn.classList.remove("hidden");
          }
        } else {
          disconnBanner.style.display = "none";
        }
      },
    });
  }
</script>
