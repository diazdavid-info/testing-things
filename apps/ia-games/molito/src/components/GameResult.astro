---
import type { PlayerKey, WinReason } from "../lib/game";

interface Props {
  winner: PlayerKey;
  playerKey: PlayerKey;
  winReason: WinReason;
  code: string;
  playerId: string;
  rematchGameCode: string | null;
}

const { winner, playerKey, winReason, code, playerId, rematchGameCode } = Astro.props;
const isWinner = winner === playerKey;

const title = isWinner ? "Has ganado!" : "Has perdido";
const icon = isWinner ? "🏆" : "😔";

const reasonTexts: Record<string, { winner: string; loser: string }> = {
  elimination: {
    winner: "Tu rival se ha quedado sin fichas",
    loser: "Te has quedado sin fichas",
  },
  block: {
    winner: "Tu rival no puede mover",
    loser: "No puedes realizar mas movimientos",
  },
  abandon: {
    winner: "Tu rival ha abandonado",
    loser: "Has perdido por abandono",
  },
};

const reasonText = winReason
  ? reasonTexts[winReason]?.[isWinner ? "winner" : "loser"] ?? ""
  : "";
---

<div
  class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4"
  id="game-result-overlay"
>
  <div class="bg-white rounded-3xl p-10 max-w-md w-full flex flex-col items-center gap-5 shadow-2xl">
    <span class="text-5xl">{icon}</span>
    <h2 class="font-heading text-2xl sm:text-3xl font-bold text-text-primary text-center">
      {title}
    </h2>
    {reasonText && (
      <p class="text-sm text-text-secondary text-center">{reasonText}</p>
    )}
    <div class="flex flex-col gap-3 w-full mt-2">
      {rematchGameCode ? (
        <a
          href={`/molino/${rematchGameCode}`}
          class="w-full h-12 bg-accent-primary hover:bg-accent-primary-hover text-white font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
        >
          Ir a revancha
        </a>
      ) : (
        <button
          id="btn-rematch"
          data-code={code}
          data-player-id={playerId}
          class="w-full h-12 bg-accent-primary hover:bg-accent-primary-hover text-white font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
        >
          Revancha
        </button>
      )}
      <a
        href="/"
        class="w-full h-12 text-text-secondary hover:text-text-primary font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </div>
</div>

<script>
  const rematchBtn = document.getElementById("btn-rematch") as HTMLButtonElement | null;
  if (rematchBtn) {
    rematchBtn.addEventListener("click", async () => {
      const code = rematchBtn.dataset.code!;
      const playerId = rematchBtn.dataset.playerId!;
      rematchBtn.disabled = true;
      rematchBtn.textContent = "Esperando rival...";
      rematchBtn.classList.remove("bg-accent-primary", "hover:bg-accent-primary-hover");
      rematchBtn.classList.add("bg-gray-300", "cursor-wait");

      try {
        const res = await fetch(`/api/games/${code}/rematch`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ playerId }),
        });
        if (res.ok) {
          const data = await res.json();
          if (data.rematchCode) {
            window.location.href = `/molino/${data.rematchCode}`;
          }
          // If waiting, SSE will reload when rival accepts
        }
      } catch {
        rematchBtn.disabled = false;
        rematchBtn.textContent = "Revancha";
        rematchBtn.classList.add("bg-accent-primary", "hover:bg-accent-primary-hover");
        rematchBtn.classList.remove("bg-gray-300", "cursor-wait");
      }
    });
  }
</script>
