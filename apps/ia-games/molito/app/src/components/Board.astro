---
import { POSITIONS, ADJACENCY, getRemovablePositions, getValidMoves } from "../lib/board";
import type { BoardCell, PlayerKey, GamePhase } from "../lib/game";

interface Props {
  board: BoardCell[];
  turn: PlayerKey;
  phase: GamePhase;
  turnState: string;
  playerKey: PlayerKey;
  code: string;
  playerId: string;
}

const { board, turn, phase, turnState, playerKey, code, playerId } = Astro.props;

const SIZE = 480;
const MARGIN = 40;
const INNER = SIZE - MARGIN * 2;
const STEP = INNER / 6;

function toPixel(gridVal: number): number {
  return MARGIN + gridVal * STEP;
}

const lines = [
  // Outer square
  [0, 1], [1, 2], [2, 14], [14, 23], [23, 22], [22, 21], [21, 9], [9, 0],
  // Middle square
  [3, 4], [4, 5], [5, 13], [13, 20], [20, 19], [19, 18], [18, 10], [10, 3],
  // Inner square
  [6, 7], [7, 8], [8, 12], [12, 17], [17, 16], [16, 15], [15, 11], [11, 6],
  // Cross lines
  [1, 4], [4, 7], [9, 10], [10, 11], [12, 13], [13, 14], [16, 19], [19, 22],
];

const canPlace = phase === "place" && turnState === "place" && turn === playerKey;
const canRemove = turnState === "remove" && turn === playerKey;
const canMove = (phase === "move" || phase === "fly") && turnState === "move" && turn === playerKey;
const removablePositions = canRemove ? new Set(getRemovablePositions(board, playerKey)) : new Set<number>();
---

<div class="w-full max-w-[480px] mx-auto" id="board-container" data-code={code} data-player-id={playerId} data-player-key={playerKey}>
  <svg
    viewBox={`0 0 ${SIZE} ${SIZE}`}
    class="w-full h-auto"
    role="img"
    aria-label="Tablero del Molino"
  >
    {lines.map(([from, to]) => {
      const p1 = POSITIONS[from];
      const p2 = POSITIONS[to];
      return (
        <line
          x1={toPixel(p1.x)}
          y1={toPixel(p1.y)}
          x2={toPixel(p2.x)}
          y2={toPixel(p2.y)}
          stroke="#3D3530"
          stroke-width="2"
          stroke-linecap="round"
        />
      );
    })}

    {POSITIONS.map((pos, idx) => {
      const cx = toPixel(pos.x);
      const cy = toPixel(pos.y);
      const cell = board[idx];
      const isEmpty = cell === null;
      const isRemovable = removablePositions.has(idx);
      const isOwnPiece = cell === playerKey;
      const isMovable = canMove && isOwnPiece && getValidMoves(board, idx).length > 0;
      const isClickable = (canPlace && isEmpty) || isRemovable || isMovable;
      const isProtectedRival = canRemove && !isEmpty && cell !== playerKey && !isRemovable;
      const adjacentEmpty = canMove && isOwnPiece ? getValidMoves(board, idx).join(",") : "";

      let fill = "#E8E4DE";
      let strokeColor = "#B0AAA2";
      let radius = 10;
      let opacity = 1;

      if (cell === "player1") {
        fill = "#C8702A";
        strokeColor = "#A85A1E";
        radius = 12;
      } else if (cell === "player2") {
        fill = "#1A1A1A";
        strokeColor = "#000000";
        radius = 12;
      }

      if (isRemovable) {
        strokeColor = "#D4A843";
        radius = 14;
      } else if (isProtectedRival) {
        opacity = 0.35;
      }

      const playerLabel = cell === "player1" ? "Jugador 1" : "Jugador 2";
      let label = isEmpty
        ? `Posicion ${idx}, vacia`
        : `Posicion ${idx}, ficha ${playerLabel}`;
      if (isRemovable) label += ", eliminable";
      if (isMovable) label += ", seleccionable";

      return (
        <>
          {isRemovable && (
            <circle
              cx={cx}
              cy={cy}
              r="18"
              fill="#D4A84330"
              class="animate-pulse"
            />
          )}
          <circle
            cx={cx}
            cy={cy}
            r={radius}
            fill={fill}
            stroke={strokeColor}
            stroke-width={isRemovable ? "3" : isEmpty ? "1" : "2"}
            opacity={opacity}
            class:list={[
              "board-position transition-all duration-150",
              isClickable && "cursor-pointer hover:opacity-80",
              !isClickable && "cursor-default",
            ]}
            data-position={idx}
            data-empty={isEmpty}
            data-clickable={isClickable}
            data-action={isRemovable ? "remove" : isMovable ? "select" : "place"}
            data-owner={cell ?? "empty"}
            data-adjacent={adjacentEmpty || undefined}
            role="button"
            aria-label={label}
            tabindex={isClickable ? "0" : "-1"}
          />
        </>
      );
    })}
  </svg>
</div>

<script>
  const container = document.getElementById("board-container")!;
  const code = container.dataset.code!;
  const playerId = container.dataset.playerId!;
  const playerKey = container.dataset.playerKey!;
  let isProcessing = false;
  let selectedFrom: number | null = null;

  function clearSelection() {
    container.querySelectorAll(".selected-piece").forEach((el) => el.classList.remove("selected-piece"));
    container.querySelectorAll(".valid-dest").forEach((el) => {
      el.classList.remove("valid-dest");
      (el as SVGCircleElement).setAttribute("data-clickable", "false");
      el.setAttribute("tabindex", "-1");
    });
    selectedFrom = null;
  }

  function selectPiece(circle: SVGCircleElement, position: number) {
    clearSelection();
    selectedFrom = position;
    circle.classList.add("selected-piece");

    const adjacent = circle.dataset.adjacent;
    if (!adjacent) return;
    const destPositions = adjacent.split(",").map(Number);
    for (const dest of destPositions) {
      const destCircle = container.querySelector(`[data-position="${dest}"]`) as SVGCircleElement | null;
      if (destCircle) {
        destCircle.classList.add("valid-dest");
        destCircle.setAttribute("data-clickable", "true");
        destCircle.setAttribute("tabindex", "0");
      }
    }
  }

  async function sendAction(action: string, body: object) {
    isProcessing = true;
    try {
      const res = await fetch(`/api/games/${code}/${action}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        window.location.reload();
      } else {
        const data = await res.json();
        console.error(`${action} error:`, data.error);
        isProcessing = false;
      }
    } catch {
      isProcessing = false;
    }
  }

  container.addEventListener("click", async (e) => {
    const target = e.target as SVGCircleElement;
    if (!target.dataset.position || isProcessing) return;

    const position = Number(target.dataset.position);
    const action = target.dataset.action;

    // Move mode: two-step flow
    if (action === "select") {
      if (selectedFrom === position) {
        clearSelection();
      } else {
        selectPiece(target, position);
      }
      return;
    }

    // Clicking a valid destination while a piece is selected
    if (selectedFrom !== null && target.classList.contains("valid-dest")) {
      await sendAction("move", { from: selectedFrom, to: position, playerId });
      return;
    }

    // If in move mode and clicking another own piece, change selection
    if (selectedFrom !== null && target.dataset.owner === playerKey && target.dataset.adjacent) {
      selectPiece(target, position);
      return;
    }

    // Place or remove actions
    if (target.dataset.clickable !== "true") return;

    if (action === "remove") {
      await sendAction("remove", { position, playerId });
    } else if (action === "place") {
      await sendAction("place", { position, playerId });
    }
  });

  // Keyboard support
  container.addEventListener("keydown", (e) => {
    if (e.key === "Enter" || e.key === " ") {
      const target = e.target as SVGCircleElement;
      if (target.dataset.clickable === "true" || target.dataset.action === "select" || target.classList.contains("valid-dest")) {
        e.preventDefault();
        (target as HTMLElement).click();
      }
    }
  });
</script>

<style>
  .selected-piece {
    filter: drop-shadow(0 0 6px rgba(200, 112, 42, 0.8));
    transform-origin: center;
  }
  .valid-dest {
    fill: rgba(76, 175, 80, 0.4) !important;
    stroke: #4CAF50 !important;
    stroke-width: 2 !important;
    cursor: pointer !important;
  }
</style>
