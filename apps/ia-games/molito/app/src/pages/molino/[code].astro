---
import Layout from "../../layouts/Layout.astro";
import WaitingRoom from "../../components/WaitingRoom.astro";
import Board from "../../components/Board.astro";
import GameInfo from "../../components/GameInfo.astro";
import GameResult from "../../components/GameResult.astro";
import { getGameByCode } from "../../lib/game";
import type { PlayerKey } from "../../lib/game";

const { code } = Astro.params;
const game = code ? getGameByCode(code) : null;

const cookieName = `playerId_${code}`;
const playerId = Astro.cookies.get(cookieName)?.value ?? null;

const isPlayer1 = playerId != null && game?.player1.id === playerId;
const isPlayer2 = playerId != null && game?.player2?.id === playerId;
const isKnownPlayer = isPlayer1 || isPlayer2;
const playerKey: PlayerKey = isPlayer2 ? "player2" : "player1";

const pageTitle = game
  ? `Partida ${code} — El Molino`
  : "Partida no encontrada — El Molino";
const pageDescription = game
  ? game.status === "playing"
    ? "Partida en curso — El Molino"
    : `Unete a la partida ${code} del Molino. Abre este link para jugar.`
  : "La partida que buscas no existe o ha expirado.";
---

<Layout title={pageTitle} description={pageDescription}>
  {!game ? (
    <div class="w-full max-w-md mx-auto px-6">
      <div class="bg-bg-surface border border-border rounded-2xl p-12 flex flex-col items-center gap-6">
        <svg class="w-12 h-12 text-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>
        </svg>
        <h1 class="font-heading text-2xl font-semibold text-text-primary">
          Partida no encontrada
        </h1>
        <p class="text-sm text-text-secondary text-center leading-relaxed">
          El codigo no existe o la partida ha expirado
        </p>
        <a
          href="/"
          class="w-full h-12 bg-accent-primary hover:bg-accent-primary-hover text-white font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
        >
          Volver al inicio
        </a>
      </div>
    </div>
  ) : game.status === "waiting" && isPlayer1 ? (
    <WaitingRoom code={code!} />
  ) : game.status === "waiting" && !isKnownPlayer ? (
    <div id="auto-join-screen" class="w-full max-w-md mx-auto px-6" data-code={code}>
      <div class="bg-bg-surface border border-border rounded-2xl p-12 flex flex-col items-center gap-6">
        <div class="w-12 h-12 rounded-full border-3 border-accent-primary border-t-transparent animate-spin"></div>
        <h1 class="font-heading text-xl font-semibold text-text-primary">
          Uniendose a la partida...
        </h1>
        <p class="text-sm text-text-secondary text-center">
          Conectando con tu rival
        </p>
        <div class="bg-bg-surface-subtle rounded-lg px-4 py-2">
          <span class="font-heading text-lg font-bold text-accent-primary tracking-[4px]">{code}</span>
        </div>
      </div>
    </div>
    <div id="join-error-screen" class="w-full max-w-md mx-auto px-6 hidden">
      <div class="bg-bg-surface border border-border rounded-2xl p-12 flex flex-col items-center gap-6">
        <span class="text-4xl" id="error-icon">🚫</span>
        <h1 class="font-heading text-2xl font-semibold text-text-primary" id="error-title">
          Error
        </h1>
        <p class="text-sm text-text-secondary text-center leading-relaxed" id="error-desc"></p>
        <p class="text-xs text-text-muted text-center">
          Puedes crear tu propia partida desde el inicio
        </p>
        <a
          href="/"
          class="w-full h-12 bg-accent-primary hover:bg-accent-primary-hover text-white font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
        >
          Volver al inicio
        </a>
      </div>
    </div>
    <div id="join-success-screen" class="w-full max-w-md mx-auto px-6 hidden">
      <div class="bg-bg-surface border border-border rounded-2xl p-12 flex flex-col items-center gap-6">
        <div class="w-14 h-14 rounded-full bg-[#E8F5E1] flex items-center justify-center">
          <svg class="w-7 h-7 text-[#4CAF50]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h1 class="font-heading text-xl font-semibold text-text-primary">
          Conectado!
        </h1>
        <p class="text-sm text-text-secondary text-center">
          La partida va a comenzar...
        </p>
        <div class="w-full h-1 bg-bg-surface-subtle rounded-full overflow-hidden">
          <div class="h-full bg-accent-primary rounded-full animate-progress"></div>
        </div>
      </div>
    </div>
  ) : game.status === "playing" && isKnownPlayer ? (
    <div class="w-full max-w-5xl mx-auto px-4 sm:px-6">
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 items-start">
        <div class="flex-1 w-full lg:max-w-[540px]">
          <Board
            board={game.board}
            turn={game.turn}
            phase={game.phase}
            turnState={game.turnState}
            playerKey={playerKey}
            code={code!}
            playerId={playerId!}
            currentPlayer={playerKey === "player1" ? game.player1 : game.player2!}
          />
        </div>
        <div class="w-full lg:w-80 bg-bg-surface border border-border rounded-2xl p-6">
          <GameInfo
            turn={game.turn}
            phase={game.phase}
            turnState={game.turnState}
            playerKey={playerKey}
            player1={{ piecesToPlace: game.player1.piecesToPlace, piecesOnBoard: game.player1.piecesOnBoard }}
            player2={{ piecesToPlace: game.player2!.piecesToPlace, piecesOnBoard: game.player2!.piecesOnBoard }}
          />
        </div>
      </div>
    </div>
  ) : game.status === "playing" && !isKnownPlayer ? (
    <div class="w-full max-w-md mx-auto px-6">
      <div class="bg-bg-surface border border-border rounded-2xl p-12 flex flex-col items-center gap-6">
        <span class="text-4xl">🚫</span>
        <h1 class="font-heading text-2xl font-semibold text-text-primary">
          Partida llena
        </h1>
        <p class="text-sm text-text-secondary text-center leading-relaxed">
          Esta partida ya tiene dos jugadores
        </p>
        <p class="text-xs text-text-muted text-center">
          Puedes crear tu propia partida desde el inicio
        </p>
        <a
          href="/"
          class="w-full h-12 bg-accent-primary hover:bg-accent-primary-hover text-white font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
        >
          Volver al inicio
        </a>
      </div>
    </div>
  ) : game.status === "finished" && isKnownPlayer ? (
    <div class="w-full max-w-5xl mx-auto px-4 sm:px-6 relative">
      <div class="flex flex-col lg:flex-row gap-6 lg:gap-10 items-start opacity-50 pointer-events-none">
        <div class="flex-1 w-full lg:max-w-[540px]">
          <Board
            board={game.board}
            turn={game.turn}
            phase={game.phase}
            turnState={game.turnState}
            playerKey={playerKey}
            code={code!}
            playerId={playerId!}
            currentPlayer={playerKey === "player1" ? game.player1 : game.player2!}
          />
        </div>
        <div class="w-full lg:w-80 bg-bg-surface border border-border rounded-2xl p-6">
          <GameInfo
            turn={game.turn}
            phase={game.phase}
            turnState={game.turnState}
            playerKey={playerKey}
            player1={{ piecesToPlace: game.player1.piecesToPlace, piecesOnBoard: game.player1.piecesOnBoard }}
            player2={{ piecesToPlace: game.player2!.piecesToPlace, piecesOnBoard: game.player2!.piecesOnBoard }}
          />
        </div>
      </div>
      <GameResult winner={game.winner!} playerKey={playerKey} winReason={game.winReason} />
    </div>
  ) : game.status === "finished" ? (
    <div class="w-full max-w-md mx-auto px-6">
      <div class="bg-bg-surface border border-border rounded-2xl p-12 flex flex-col items-center gap-6">
        <span class="text-4xl">⏱️</span>
        <h1 class="font-heading text-2xl font-semibold text-text-primary">
          Partida terminada
        </h1>
        <p class="text-sm text-text-secondary text-center leading-relaxed">
          Esta partida ya ha finalizado
        </p>
        <a
          href="/"
          class="w-full h-12 bg-accent-primary hover:bg-accent-primary-hover text-white font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
        >
          Volver al inicio
        </a>
      </div>
    </div>
  ) : null}
</Layout>

{game && game.status === "waiting" && (
  <Fragment>
    <meta slot="head" property="og:title" content="Te han retado a jugar al Molino!" />
    <meta slot="head" property="og:description" content="Abre este link para unirte a la partida y empezar a jugar" />
  </Fragment>
)}
{game && game.status === "playing" && (
  <Fragment>
    <meta slot="head" property="og:title" content="Partida en curso — El Molino" />
    <meta slot="head" property="og:description" content="Esta partida ya esta en curso. Crea tu propia partida para jugar." />
  </Fragment>
)}

<style>
  @keyframes progress {
    from { width: 0%; }
    to { width: 100%; }
  }
  .animate-progress {
    animation: progress 1.2s ease-in-out forwards;
  }
</style>

<script>
  // SSE real-time sync
  const boardContainer = document.getElementById("board-container");
  const waitingRoom = document.getElementById("waiting-room");
  const gameCode = boardContainer?.dataset.code || waitingRoom?.dataset.code;
  const connIndicator = document.getElementById("conn-indicator");

  if (gameCode && (boardContainer || waitingRoom)) {
    let lastState = "";
    let retryDelay = 1000;

    function connectSSE() {
      const es = new EventSource(`/api/games/${gameCode}/stream`);

      es.onopen = () => {
        retryDelay = 1000;
        if (connIndicator) {
          connIndicator.dataset.status = "connected";
          connIndicator.textContent = "";
        }
      };

      es.onmessage = (event) => {
        if (!event.data) return;
        const stateStr = event.data;
        if (lastState && stateStr !== lastState) {
          window.location.reload();
        }
        lastState = stateStr;
      };

      es.onerror = () => {
        es.close();
        if (connIndicator) {
          connIndicator.dataset.status = "disconnected";
          connIndicator.textContent = "Reconectando...";
        }
        setTimeout(connectSSE, retryDelay);
        retryDelay = Math.min(retryDelay * 2, 30_000);
      };
    }

    connectSSE();
  }

  const autoJoinScreen = document.getElementById("auto-join-screen");
  if (autoJoinScreen) {
    const code = autoJoinScreen.dataset.code!;
    const errorScreen = document.getElementById("join-error-screen")!;
    const successScreen = document.getElementById("join-success-screen")!;

    async function attemptAutoJoin() {
      try {
        const res = await fetch(`/api/games/${code}/join`, { method: "POST" });

        if (res.ok) {
          autoJoinScreen!.classList.add("hidden");
          successScreen.classList.remove("hidden");
          setTimeout(() => {
            window.location.reload();
          }, 1500);
          return;
        }

        autoJoinScreen!.classList.add("hidden");
        errorScreen.classList.remove("hidden");

        const errorTitle = document.getElementById("error-title")!;
        const errorDesc = document.getElementById("error-desc")!;
        const errorIcon = document.getElementById("error-icon")!;

        if (res.status === 409) {
          errorIcon.textContent = "🚫";
          errorTitle.textContent = "Partida llena";
          errorDesc.textContent = "Esta partida ya tiene dos jugadores";
        } else if (res.status === 410) {
          errorIcon.textContent = "⏱️";
          errorTitle.textContent = "Partida terminada";
          errorDesc.textContent = "Esta partida ya ha finalizado";
        } else {
          errorIcon.textContent = "❌";
          errorTitle.textContent = "Error al unirse";
          errorDesc.textContent = "No se pudo unir a la partida. Intentalo de nuevo.";
        }
      } catch {
        autoJoinScreen!.classList.add("hidden");
        errorScreen.classList.remove("hidden");
        const errorTitle = document.getElementById("error-title")!;
        const errorDesc = document.getElementById("error-desc")!;
        errorTitle.textContent = "Error de conexion";
        errorDesc.textContent = "No se pudo conectar al servidor. Intentalo de nuevo.";
      }
    }

    attemptAutoJoin();
  }
</script>
