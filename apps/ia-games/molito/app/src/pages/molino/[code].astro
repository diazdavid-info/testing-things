---
import Layout from "../../layouts/Layout.astro";
import WaitingRoom from "../../components/WaitingRoom.astro";
import { getGameByCode } from "../../lib/game";

const { code } = Astro.params;
const game = code ? getGameByCode(code) : null;

const pageTitle = game
  ? `Partida ${code} — El Molino`
  : "Partida no encontrada — El Molino";
const pageDescription = game
  ? `Unete a la partida ${code} del Molino. Abre este link para jugar.`
  : "La partida que buscas no existe o ha expirado.";
---

<Layout title={pageTitle} description={pageDescription}>
  {!game ? (
    <div class="w-full max-w-md mx-auto px-6">
      <div class="bg-bg-surface border border-border rounded-2xl p-12 flex flex-col items-center gap-6">
        <svg class="w-12 h-12 text-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/>
        </svg>
        <h1 class="font-heading text-2xl font-semibold text-text-primary">
          Partida no encontrada
        </h1>
        <p class="text-sm text-text-secondary text-center leading-relaxed">
          El codigo no existe o la partida ha expirado
        </p>
        <a
          href="/"
          class="w-full h-12 bg-accent-primary hover:bg-accent-primary-hover text-white font-heading font-semibold text-sm rounded-[10px] flex items-center justify-center transition-colors"
        >
          Volver al inicio
        </a>
      </div>
    </div>
  ) : game.status === "waiting" ? (
    <WaitingRoom code={code!} />
  ) : (
    <div class="text-center">
      <h1 class="font-heading text-2xl font-semibold text-text-primary">
        Partida en curso
      </h1>
      <p class="text-sm text-text-secondary mt-2">
        El tablero se implementara en stories posteriores
      </p>
    </div>
  )}
</Layout>

{game && (
  <Fragment>
    <meta slot="head" property="og:title" content="Te han retado a jugar al Molino!" />
    <meta slot="head" property="og:description" content="Abre este link para unirte a la partida y empezar a jugar" />
  </Fragment>
)}
